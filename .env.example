# ── LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Search providers (search layer is pluggable; default = brave) ────
# Get a Brave key at https://brave.com/search/api/  (free tier ~2000/mo)
BRAVE_API_KEY=
# Optional fallback for Chinese-language coverage (Google SERP via serper.dev)
SERPER_API_KEY=
# Force a provider for local dev without keys: brave | serper | mock
SEARCH_PROVIDER=mock

# ── Auth (single user, private site) ────────────────────────────────
AUTH_USERNAME=gipi
# bcrypt hash of the password. Generate with: npm run -s hash -- 'your-password'
AUTH_PASSWORD_HASH=
# 32+ char random string for signing the session cookie
AUTH_SECRET=change-me-to-a-long-random-string

# Shared secret the cron job presents to POST /api/cron (Authorization: Bearer ...)
CRON_SECRET=change-me-too

# ── DB ──────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── Notifications (optional) ────────────────────────────────────────
NOTIFY_EMAIL=james00668@gmail.com
# Resend API key for the post-run email (optional; leave blank to skip)
RESEND_API_KEY=

# Public base URL (used in notification links). e.g. https://digest.example.com
APP_BASE_URL=http://localhost:3000
